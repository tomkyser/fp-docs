{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run pre-tool-use bash"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run session-start inject-manifest"
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run session-start branch-sync"
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run session-start drift-nudge"
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run session-start update-check"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "modify",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop modify"
          }
        ]
      },
      {
        "matcher": "orchestrate",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop orchestrate"
          }
        ]
      },
      {
        "matcher": "locals",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop locals"
          }
        ]
      },
      {
        "matcher": "validate",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop validate"
          }
        ]
      },
      {
        "matcher": "citations",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop citations"
          }
        ]
      },
      {
        "matcher": "api-refs",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop api-refs"
          }
        ]
      },
      {
        "matcher": "researcher",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop researcher"
          }
        ]
      },
      {
        "matcher": "planner",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run subagent-stop planner"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run teammate-idle"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/fp-tools.cjs\" hooks run task-completed"
          }
        ]
      }
    ]
  }
}
